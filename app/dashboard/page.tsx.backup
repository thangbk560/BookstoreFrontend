"use client";

import { useState, useEffect } from "react";
import { Header } from "@/components/layout/Header";
import { Footer } from "@/components/layout/Footer";
import { Card } from "@/components/ui/Card";
import { Button } from "@/components/ui/Button";
import { Input } from "@/components/ui/Input";
import { useLanguage } from "@/lib/contexts/LanguageContext";
import { useAuth } from "@/lib/contexts/AuthContext";
import { User, Package, MapPin, Settings as SettingsIcon, LogOut, ShoppingBag, Heart, BarChart3, BookOpen, FolderOpen, Pencil, Trash2, Plus } from "lucide-react";
import { useRouter } from "next/navigation";
import { favoritesApi } from "@/lib/api/favorites";
import { usersApi, Address } from "@/lib/api/users";
import { authApi } from "@/lib/api/auth";

interface Order {
    _id: string;
    orderNumber: string;
    total: number;
    status: string;
    createdAt: string;
    items: Array<{
        book: {
            title: string;
        };
        title?: string;
        quantity: number;
        price: number;
    }>;
    user?: {
        name: string;
        email: string;
    };
}

interface DashboardStats {
    totalBooks: number;
    totalOrders: number;
    totalRevenue: number;
    recentOrders: Order[];
    ordersByStatus: Array<{ _id: string; count: number }>;
}

interface Book {
    _id: string;
    title: string;
    author: string;
    price: number;
    category: string;
    stock: number;
    images?: string[];
    soldCount?: number;
}

interface Category {
    _id: string;
    name: string;
    slug: string;
    description?: string;
}

export default function DashboardPage() {
    const { t } = useLanguage();
    const { user, logout, isAuthenticated, loading: authLoading, setAuth } = useAuth();
    const router = useRouter();

    // User tabs
    const [activeTab, setActiveTab] = useState<"orders" | "profile" | "addresses" | "settings" | "favorites">("orders");

    // Admin tabs
    const [adminTab, setAdminTab] = useState<"statistics" | "orders" | "books" | "categories">("statistics");

    const [orders, setOrders] = useState<Order[]>([]);
    const [stats, setStats] = useState<DashboardStats | null>(null);
    const [favorites, setFavorites] = useState<any[]>([]);
    const [addresses, setAddresses] = useState<Address[]>([]);
    const [loading, setLoading] = useState(false);

    // Admin management state
    const [books, setBooks] = useState<Book[]>([]);
    const [categories, setCategories] = useState<Category[]>([]);
    const [selectedBook, setSelectedBook] = useState<Book | null>(null);
    const [selectedCategory, setSelectedCategory] = useState<Category | null>(null);
    const [showBookModal, setShowBookModal] = useState(false);
    const [showCategoryModal, setShowCategoryModal] = useState(false);

    // Profile State
    const [profileData, setProfileData] = useState({ name: "", email: "", phone: "" });
    const [profileLoading, setProfileLoading] = useState(false);

    // Password State
    const [passwordData, setPasswordData] = useState({ currentPassword: "", newPassword: "", confirmPassword: "" });
    const [passwordLoading, setPasswordLoading] = useState(false);

    // Address State
    const [showAddressModal, setShowAddressModal] = useState(false);
    const [newAddress, setNewAddress] = useState<Address>({
        fullName: "",
        phone: "",
        address: "",
        city: "",
        zipCode: "",
        isDefault: false
    });
    const [addressLoading, setAddressLoading] = useState(false);

    const isAdmin = user?.role === 'admin';

    useEffect(() => {
        // Don't redirect if still loading auth state
        if (authLoading) {
            return;
        }

        if (!isAuthenticated) {
            router.push("/auth/login");
            return;
        }

        if (isAdmin) {
            fetchAdminStats();
        } else if (activeTab === "orders") {
            fetchOrders();
        } else if (activeTab === "favorites") {
            fetchFavorites();
        } else if (activeTab === "addresses") {
            fetchAddresses();
        }
    }, [isAuthenticated, authLoading, activeTab, isAdmin]);

    useEffect(() => {
        if (user) {
            setProfileData({
                name: user.name || "",
                email: user.email || "",
                phone: user.phone || ""
            });
        }
    }, [user]);

    const fetchOrders = async () => {
        try {
            setLoading(true);
            const response = await fetch("http://localhost:3001/api/orders/my-orders", {
                headers: {
                    Authorization: `Bearer ${localStorage.getItem("access_token")}`,
                },
            });

            if (response.ok) {
                const data = await response.json();
                setOrders(data);
            }
        } catch (error) {
            console.error("Error fetching orders:", error);
        } finally {
            setLoading(false);
        }
    };

    const fetchAddresses = async () => {
        try {
            setLoading(true);
            const data = await usersApi.getAddresses();
            setAddresses(data);
        } catch (error) {
            console.error("Error fetching addresses:", error);
        } finally {
            setLoading(false);
        }
    };

    const handleUpdateProfile = async () => {
        try {
            setProfileLoading(true);
            const updatedUser = await usersApi.updateProfile(profileData);
            // Update local user state
            setAuth({ user: updatedUser, isAuthenticated: true });
            alert("Cập nhật thông tin thành công!");
        } catch (error) {
            console.error("Error updating profile:", error);
            alert("Cập nhật thất bại. Vui lòng thử lại.");
        } finally {
            setProfileLoading(false);
        }
    };

    // Admin specific functions
    const fetchAdminStats = async () => {
        try {
            setLoading(true);
            const response = await fetch("http://localhost:3001/api/stats/dashboard", {
                headers: {
                    Authorization: `Bearer ${localStorage.getItem("access_token")}`,
                },
            });
            if (response.ok) {
                const data = await response.json();
                setStats(data);
            } else {
                const errorText = await response.text();
                console.error(`Failed to fetch admin stats. Status: ${response.status}, Response:`, errorText);
            }
        } catch (error) {
            console.error("Error fetching admin stats:", error);
        } finally {
            setLoading(false);
        }
    };

    const fetchFavorites = async () => {
        try {
            setLoading(true);
            const data = await favoritesApi.getFavorites();
            setFavorites(data);
        } catch (error) {
            console.error("Error fetching favorites:", error);
        } finally {
            setLoading(false);
        }
    };

    const handleAddAddress = async () => {
        try {
            setAddressLoading(true);
            const addedAddress = await usersApi.addAddress(newAddress);
            setAddresses([...addresses, addedAddress]);
            setNewAddress({
                fullName: "",
                phone: "",
                address: "",
                city: "",
                zipCode: "",
                isDefault: false
            });
            setShowAddressModal(false);
            alert("Địa chỉ đã được thêm thành công!");
        } catch (error) {
            console.error("Error adding address:", error);
            alert("Thêm địa chỉ thất bại. Vui lòng thử lại.");
        } finally {
            setAddressLoading(false);
        }
    };

    const handleDeleteAddress = async (addressId: string) => {
        if (!confirm("Bạn có chắc chắn muốn xóa địa chỉ này?")) {
            return;
        }
        try {
            setLoading(true);
            await usersApi.deleteAddress(addressId);
            setAddresses(addresses.filter(addr => addr._id !== addressId));
            alert("Địa chỉ đã được xóa thành công!");
        } catch (error) {
            console.error("Error deleting address:", error);
            alert("Xóa địa chỉ thất bại. Vui lòng thử lại.");
        } finally {
            setLoading(false);
        }
    };

    const handleChangePassword = async () => {
        if (passwordData.newPassword !== passwordData.confirmPassword) {
            alert("Mật khẩu mới và xác nhận mật khẩu không khớp.");
            return;
        }
        try {
            setPasswordLoading(true);
            await usersApi.changePassword({
                currentPassword: passwordData.currentPassword,
                newPassword: passwordData.newPassword
            });
            alert("Mật khẩu đã được thay đổi thành công!");
            setPasswordData({ currentPassword: "", newPassword: "", confirmPassword: "" });
        } catch (error: any) {
            console.error("Error changing password:", error);
            alert(`Thay đổi mật khẩu thất bại: ${error.message || "Vui lòng thử lại."}`);
        } finally {
            setPasswordLoading(false);
        }
    };

    const handleLogout = () => {
        logout();
        router.push("/auth/login");
    };

    const getStatusColor = (status: string) => {
        switch (status) {
            case "pending":
                return "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-300";
            case "processing":
                return "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-300";
            case "shipped":
                return "bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-300";
            case "delivered":
                return "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-300";
            case "cancelled":
                return "bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-300";
            default:
                return "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300";
        }
    };

    const getStatusText = (status: string) => {
        switch (status) {
            case "pending":
                return "Đang chờ";
            case "processing":
                return "Đang xử lý";
            case "shipped":
                return "Đang giao";
            case "delivered":
                return "Đã giao";
            case "cancelled":
                return "Đã hủy";
            default:
                return status;
        }
    };

    return (
        <div className="min-h-screen">
            <Header />

            <div className="container mx-auto py-8">
                <div className="mb-8">
                    <h1 className="text-4xl font-bold mb-2">{t("dashboard")}</h1>
                    <p className="text-light-text-secondary dark:text-dark-text-secondary">
                        {t("welcomeBack")}, {user?.name}!
                    </p>
                </div>

                <div className="grid lg:grid-cols-4 gap-8">
                    {/* Sidebar */}
                    <div className="lg:col-span-1">
                        <Card className="p-6">
                            <nav className="space-y-2">
                                {isAdmin ? (
                                    // Simplified admin sidebar - only logout
                                    <button
                                        onClick={handleLogout}
                                        className="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                                    >
                                        <LogOut className="w-5 h-5" />
                                        {t("logout")}
                                    </button>
                                ) : (
                                    // Regular user sidebar
                                    <>
                                        <button
                                            onClick={() => setActiveTab("orders")}
                                            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${activeTab === "orders"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <Package className="w-5 h-5" />
                                            {t("myOrders")}
                                        </button>
                                        <button
                                            onClick={() => setActiveTab("profile")}
                                            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${activeTab === "profile"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <User className="w-5 h-5" />
                                            {t("myProfile")}
                                        </button>
                                        <button
                                            onClick={() => setActiveTab("addresses")}
                                            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${activeTab === "addresses"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <MapPin className="w-5 h-5" />
                                            {t("savedAddresses")}
                                        </button>
                                        <button
                                            onClick={() => setActiveTab("favorites")}
                                            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${activeTab === "favorites"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <Heart className="w-5 h-5" />
                                            Yêu thích
                                        </button>
                                        <button
                                            onClick={() => setActiveTab("settings")}
                                            className={`w-full flex items-center gap-3 px-4 py-3 rounded-lg transition-colors ${activeTab === "settings"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <SettingsIcon className="w-5 h-5" />
                                            {t("settings")}
                                        </button>
                                        <button
                                            onClick={handleLogout}
                                            className="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-red-600 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                                        >
                                            <LogOut className="w-5 h-5" />
                                            {t("logout")}
                                        </button>
                                    </>
                                )}
                            </nav>
                        </Card>
                    </div>

                    {/* Main Content */}
                    <div className="lg:col-span-3">
                        {isAdmin ? (
                            // Admin Dashboard with tab navigation
                            <div className="space-y-6">
                                {/* Admin Navigation Tabs */}
                                <Card className="p-2">
                                    <div className="flex gap-2">
                                        <button
                                            onClick={() => setAdminTab("statistics")}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg transition-colors ${adminTab === "statistics"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <BarChart3 className="w-4 h-4" />
                                            Thống kê
                                        </button>
                                        <button
                                            onClick={() => setAdminTab("orders")}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg transition-colors ${adminTab === "orders"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <Package className="w-4 h-4" />
                                            Đơn hàng
                                        </button>
                                        <button
                                            onClick={() => setAdminTab("books")}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg transition-colors ${adminTab === "books"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <BookOpen className="w-4 h-4" />
                                            Quản lý sách
                                        </button>
                                        <button
                                            onClick={() => setAdminTab("categories")}
                                            className={`flex items-center gap-2 px-4 py-2 rounded-lg transition-colors ${adminTab === "categories"
                                                ? "bg-primary text-white"
                                                : "text-light-text-secondary dark:text-dark-text-secondary hover:bg-light-border dark:hover:bg-dark-border"
                                                }`}
                                        >
                                            <FolderOpen className="w-4 h-4" />
                                            Danh mục
                                        </button>
                                    </div>
                                </Card>
                                <div className="space-y-6">
                                    <div className="flex justify-between items-center mb-6">
                                        <h2 className="text-2xl font-bold">Admin Dashboard</h2>
                                    </div>

                                    {/* Statistics Cards */}
                                    {loading ? (
                                        <div className="text-center py-12">
                                            <div className="text-light-text-secondary dark:text-dark-text-secondary">
                                                {t("loading")}
                                            </div>
                                        </div>
                                    ) : stats ? (
                                        <>
                                            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                                                <Card className="p-6">
                                                    <div className="flex items-center justify-between">
                                                        <div>
                                                            <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">Tổng sách</p>
                                                            <p className="text-3xl font-bold mt-2">{stats.totalBooks}</p>
                                                        </div>
                                                        <ShoppingBag className="w-12 h-12 text-primary opacity-20" />
                                                    </div>
                                                </Card>

                                                <Card className="p-6">
                                                    <div className="flex items-center justify-between">
                                                        <div>
                                                            <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">Tổng đơn hàng</p>
                                                            <p className="text-3xl font-bold mt-2">{stats.totalOrders}</p>
                                                        </div>
                                                        <Package className="w-12 h-12 text-primary opacity-20" />
                                                    </div>
                                                </Card>

                                                <Card className="p-6">
                                                    <div className="flex items-center justify-between">
                                                        <div>
                                                            <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">Doanh thu</p>
                                                            <p className="text-3xl font-bold mt-2">{stats.totalRevenue.toLocaleString('vi-VN')} ₫</p>
                                                        </div>
                                                        <div className="w-12 h-12 text-green-600 opacity-20 flex items-center justify-center text-4xl">₫</div>
                                                    </div>
                                                </Card>
                                            </div>

                                            {/* Quick Actions */}
                                            <Card className="p-6">
                                                <h3 className="font-bold mb-4">Quản lý nhanh</h3>
                                                <div className="grid grid-cols-2 md:grid-cols-3 gap-4">
                                                    <Button onClick={() => router.push("/books")} variant="outline" className="flex items-center gap-2">
                                                        <ShoppingBag className="w-4 h-4" /> Quản lý sách
                                                    </Button>
                                                    <Button onClick={() => router.push("/categories")} variant="outline" className="flex items-center gap-2">
                                                        <Package className="w-4 h-4" /> Danh mục
                                                    </Button>
                                                    <Button onClick={() => setActiveTab("orders")} variant="outline" className="flex items-center gap-2">
                                                        <Package className="w-4 h-4" /> Xem đơn hàng
                                                    </Button>
                                                </div>
                                            </Card>

                                            {/* Recent Orders */}
                                            <div>
                                                <h3 className="text-xl font-bold mb-4">Đơn hàng gần đây</h3>
                                                <div className="space-y-4">
                                                    {stats.recentOrders.slice(0, 5).map((order) => (
                                                        <Card key={order._id} className="p-4">
                                                            <div className="flex justify-between items-start">
                                                                <div>
                                                                    <div className="font-semibold">#{order.orderNumber || order._id.slice(-8)}</div>
                                                                    <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                                        {order.user?.name || order.user?.email}
                                                                    </p>
                                                                    <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                                        {new Date(order.createdAt).toLocaleDateString("vi-VN")}
                                                                    </p>
                                                                </div>
                                                                <div className="text-right">
                                                                    <p className="font-bold text-primary">{order.total?.toLocaleString('vi-VN')} ₫</p>
                                                                    <span className={`px-3 py-1 rounded-full text-xs font-semibold ${getStatusColor(order.status)}`}>
                                                                        {getStatusText(order.status)}
                                                                    </span>
                                                                </div>
                                                            </div>
                                                        </Card>
                                                    ))}
                                                </div>
                                            </div>
                                        </>
                                    ) : null}
                                </div>
                                ) : (
                                // User Dashboard
                                <>
                                    {activeTab === "orders" && (
                                        <div className="space-y-6">
                                            <h2 className="text-2xl font-bold">{t("myOrders")}</h2>

                                            {loading ? (
                                                <div className="text-center py-12">
                                                    <div className="text-light-text-secondary dark:text-dark-text-secondary">
                                                        {t("loading")}
                                                    </div>
                                                </div>
                                            ) : orders.length === 0 ? (
                                                <Card className="p-12 text-center">
                                                    <ShoppingBag className="w-16 h-16 mx-auto mb-4 text-light-text-tertiary dark:text-dark-text-tertiary" />
                                                    <h3 className="text-xl font-semibold mb-2">{t("emptyCart")}</h3>
                                                    <p className="text-light-text-secondary dark:text-dark-text-secondary mb-6">
                                                        Bạn chưa có đơn hàng nào
                                                    </p>
                                                    <Button onClick={() => router.push("/books")}>
                                                        {t("browseBooks")}
                                                    </Button>
                                                </Card>
                                            ) : (
                                                orders.map((order) => (
                                                    <Card key={order._id} className="p-6">
                                                        <div className="flex justify-between items-start mb-4">
                                                            <div>
                                                                <h3 className="font-semibold text-lg">
                                                                    {t("orderNumber")}: #{order.orderNumber || order._id.slice(-8)}
                                                                </h3>
                                                                <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                                    {new Date(order.createdAt).toLocaleDateString("vi-VN")}
                                                                </p>
                                                            </div>
                                                            <span className={`px-3 py-1 rounded-full text-sm font-semibold ${getStatusColor(order.status)}`}>
                                                                {getStatusText(order.status)}
                                                            </span>
                                                        </div>

                                                        <div className="space-y-2 mb-4">
                                                            {order.items?.map((item, index) => (
                                                                <div key={index} className="flex justify-between text-sm">
                                                                    <span>{item.book?.title || item.title || "Sản phẩm"} x{item.quantity}</span>
                                                                    <span>{(item.price * item.quantity).toLocaleString('vi-VN')} ₫</span>
                                                                </div>
                                                            ))}
                                                        </div>

                                                        <div className="border-t border-light-border dark:border-dark-border pt-4 flex justify-between items-center">
                                                            <span className="font-semibold">{t("total")}:</span>
                                                            <span className="text-xl font-bold text-primary">
                                                                {order.total?.toLocaleString('vi-VN')} ₫
                                                            </span>
                                                        </div>
                                                    </Card>
                                                ))
                                            )}
                                        </div>
                                    )}

                                    {activeTab === "profile" && (
                                        <div className="space-y-6">
                                            <h2 className="text-2xl font-bold">{t("myProfile")}</h2>
                                            <Card className="p-6">
                                                <div className="space-y-4">
                                                    <Input
                                                        label={t("fullName")}
                                                        value={profileData.name}
                                                        onChange={(e) => setProfileData({ ...profileData, name: e.target.value })}
                                                    />
                                                    <Input
                                                        label={t("email")}
                                                        value={profileData.email}
                                                        readOnly
                                                        className="bg-gray-100 dark:bg-gray-800 cursor-not-allowed"
                                                    />
                                                    <Input
                                                        label={t("phone")}
                                                        value={profileData.phone}
                                                        onChange={(e) => setProfileData({ ...profileData, phone: e.target.value })}
                                                    />
                                                    <div className="pt-4">
                                                        <Button onClick={handleUpdateProfile} disabled={profileLoading}>
                                                            {profileLoading ? "Đang lưu..." : t("save")}
                                                        </Button>
                                                    </div>
                                                </div>
                                            </Card>
                                        </div>
                                    )}

                                    {activeTab === "addresses" && (
                                        <div className="space-y-6">
                                            <h2 className="text-2xl font-bold">{t("savedAddresses")}</h2>

                                            {showAddressModal ? (
                                                <Card className="p-6">
                                                    <h3 className="font-bold mb-4">Thêm địa chỉ mới</h3>
                                                    <div className="space-y-4">
                                                        <Input
                                                            label={t("fullName")}
                                                            value={newAddress.fullName}
                                                            onChange={(e) => setNewAddress({ ...newAddress, fullName: e.target.value })}
                                                        />
                                                        <Input
                                                            label={t("phone")}
                                                            value={newAddress.phone}
                                                            onChange={(e) => setNewAddress({ ...newAddress, phone: e.target.value })}
                                                        />
                                                        <Input
                                                            label={t("address")}
                                                            value={newAddress.address}
                                                            onChange={(e) => setNewAddress({ ...newAddress, address: e.target.value })}
                                                        />
                                                        <div className="grid grid-cols-2 gap-4">
                                                            <Input
                                                                label={t("city")}
                                                                value={newAddress.city}
                                                                onChange={(e) => setNewAddress({ ...newAddress, city: e.target.value })}
                                                            />
                                                            <Input
                                                                label={t("zipCode")}
                                                                value={newAddress.zipCode}
                                                                onChange={(e) => setNewAddress({ ...newAddress, zipCode: e.target.value })}
                                                            />
                                                        </div>
                                                        <div className="flex gap-4 pt-4">
                                                            <Button onClick={handleAddAddress} disabled={addressLoading}>
                                                                {addressLoading ? "Đang lưu..." : "Lưu địa chỉ"}
                                                            </Button>
                                                            <Button variant="outline" onClick={() => setShowAddressModal(false)}>
                                                                Hủy
                                                            </Button>
                                                        </div>
                                                    </div>
                                                </Card>
                                            ) : (
                                                <>
                                                    {addresses.length === 0 ? (
                                                        <Card className="p-12 text-center">
                                                            <MapPin className="w-16 h-16 mx-auto mb-4 text-light-text-tertiary dark:text-dark-text-tertiary" />
                                                            <p className="text-light-text-secondary dark:text-dark-text-secondary mb-6">
                                                                Chưa có địa chỉ nào được lưu
                                                            </p>
                                                            <Button onClick={() => setShowAddressModal(true)}>Thêm địa chỉ mới</Button>
                                                        </Card>
                                                    ) : (
                                                        <div className="space-y-4">
                                                            {addresses.map((addr) => (
                                                                <Card key={addr._id} className="p-6 flex justify-between items-start">
                                                                    <div>
                                                                        <div className="font-bold mb-1">{addr.fullName}</div>
                                                                        <div className="text-sm text-light-text-secondary dark:text-dark-text-secondary">{addr.phone}</div>
                                                                        <div className="text-sm text-light-text-secondary dark:text-dark-text-secondary">{addr.address}, {addr.city}</div>
                                                                    </div>
                                                                    <Button variant="outline" size="sm" onClick={() => handleDeleteAddress(addr._id!)}>
                                                                        Xóa
                                                                    </Button>
                                                                </Card>
                                                            ))}
                                                            <Button onClick={() => setShowAddressModal(true)}>Thêm địa chỉ mới</Button>
                                                        </div>
                                                    )}
                                                </>
                                            )}
                                        </div>
                                    )}

                                    {activeTab === "favorites" && (
                                        <div className="space-y-6">
                                            <div>
                                                <div className="font-semibold">#{order.orderNumber || order._id.slice(-8)}</div>
                                                <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                    {order.user?.name || order.user?.email}
                                                </p>
                                                <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                    {new Date(order.createdAt).toLocaleDateString("vi-VN")}
                                                </p>
                                            </div>
                                            <div className="text-right">
                                                <p className="font-bold text-primary">{order.total?.toLocaleString('vi-VN')} ₫</p>
                                                <span className={`px-3 py-1 rounded-full text-xs font-semibold ${getStatusColor(order.status)}`}>
                                                    {getStatusText(order.status)}
                                                </span>
                                            </div>
                                        </div>
                                                        </Card>
                                                    ))}
                            </div>
                                            </div>
                </>
                                    ) : null}
            </div>
            ) : (
            // User Dashboard
            <>
                {activeTab === "orders" && (
                    <div className="space-y-6">
                        <h2 className="text-2xl font-bold">{t("myOrders")}</h2>

                        {loading ? (
                            <div className="text-center py-12">
                                <div className="text-light-text-secondary dark:text-dark-text-secondary">
                                    {t("loading")}
                                </div>
                            </div>
                        ) : orders.length === 0 ? (
                            <Card className="p-12 text-center">
                                <ShoppingBag className="w-16 h-16 mx-auto mb-4 text-light-text-tertiary dark:text-dark-text-tertiary" />
                                <h3 className="text-xl font-semibold mb-2">{t("emptyCart")}</h3>
                                <p className="text-light-text-secondary dark:text-dark-text-secondary mb-6">
                                    Bạn chưa có đơn hàng nào
                                </p>
                                <Button onClick={() => router.push("/books")}>
                                    {t("browseBooks")}
                                </Button>
                            </Card>
                        ) : (
                            orders.map((order) => (
                                <Card key={order._id} className="p-6">
                                    <div className="flex justify-between items-start mb-4">
                                        <div>
                                            <h3 className="font-semibold text-lg">
                                                {t("orderNumber")}: #{order.orderNumber || order._id.slice(-8)}
                                            </h3>
                                            <p className="text-sm text-light-text-tertiary dark:text-dark-text-tertiary">
                                                {new Date(order.createdAt).toLocaleDateString("vi-VN")}
                                            </p>
                                        </div>
                                        <span className={`px-3 py-1 rounded-full text-sm font-semibold ${getStatusColor(order.status)}`}>
                                            {getStatusText(order.status)}
                                        </span>
                                    </div>

                                    <div className="space-y-2 mb-4">
                                        {order.items?.map((item, index) => (
                                            <div key={index} className="flex justify-between text-sm">
                                                <span>{item.book?.title || item.title || "Sản phẩm"} x{item.quantity}</span>
                                                <span>{(item.price * item.quantity).toLocaleString('vi-VN')} ₫</span>
                                            </div>
                                        ))}
                                    </div>

                                    <div className="border-t border-light-border dark:border-dark-border pt-4 flex justify-between items-center">
                                        <span className="font-semibold">{t("total")}:</span>
                                        <span className="text-xl font-bold text-primary">
                                            {order.total?.toLocaleString('vi-VN')} ₫
                                        </span>
                                    </div>
                                </Card>
                            ))
                        )}
                    </div>
                )}

                {activeTab === "profile" && (
                    <div className="space-y-6">
                        <h2 className="text-2xl font-bold">{t("myProfile")}</h2>
                        <Card className="p-6">
                            <div className="space-y-4">
                                <Input
                                    label={t("fullName")}
                                    value={profileData.name}
                                    onChange={(e) => setProfileData({ ...profileData, name: e.target.value })}
                                />
                                <Input
                                    label={t("email")}
                                    value={profileData.email}
                                    readOnly
                                    className="bg-gray-100 dark:bg-gray-800 cursor-not-allowed"
                                />
                                <Input
                                    label={t("phone")}
                                    value={profileData.phone}
                                    onChange={(e) => setProfileData({ ...profileData, phone: e.target.value })}
                                />
                                <div className="pt-4">
                                    <Button onClick={handleUpdateProfile} disabled={profileLoading}>
                                        {profileLoading ? "Đang lưu..." : t("save")}
                                    </Button>
                                </div>
                            </div>
                        </Card>
                    </div>
                )}

                {activeTab === "addresses" && (
                    <div className="space-y-6">
                        <h2 className="text-2xl font-bold">{t("savedAddresses")}</h2>

                        {showAddressModal ? (
                            <Card className="p-6">
                                <h3 className="font-bold mb-4">Thêm địa chỉ mới</h3>
                                <div className="space-y-4">
                                    <Input
                                        label={t("fullName")}
                                        value={newAddress.fullName}
                                        onChange={(e) => setNewAddress({ ...newAddress, fullName: e.target.value })}
                                    />
                                    <Input
                                        label={t("phone")}
                                        value={newAddress.phone}
                                        onChange={(e) => setNewAddress({ ...newAddress, phone: e.target.value })}
                                    />
                                    <Input
                                        label={t("address")}
                                        value={newAddress.address}
                                        onChange={(e) => setNewAddress({ ...newAddress, address: e.target.value })}
                                    />
                                    <div className="grid grid-cols-2 gap-4">
                                        <Input
                                            label={t("city")}
                                            value={newAddress.city}
                                            onChange={(e) => setNewAddress({ ...newAddress, city: e.target.value })}
                                        />
                                        <Input
                                            label={t("zipCode")}
                                            value={newAddress.zipCode}
                                            onChange={(e) => setNewAddress({ ...newAddress, zipCode: e.target.value })}
                                        />
                                    </div>
                                    <div className="flex gap-4 pt-4">
                                        <Button onClick={handleAddAddress} disabled={addressLoading}>
                                            {addressLoading ? "Đang lưu..." : "Lưu địa chỉ"}
                                        </Button>
                                        <Button variant="outline" onClick={() => setShowAddressModal(false)}>
                                            Hủy
                                        </Button>
                                    </div>
                                </div>
                            </Card>
                        ) : (
                            <>
                                {addresses.length === 0 ? (
                                    <Card className="p-12 text-center">
                                        <MapPin className="w-16 h-16 mx-auto mb-4 text-light-text-tertiary dark:text-dark-text-tertiary" />
                                        <p className="text-light-text-secondary dark:text-dark-text-secondary mb-6">
                                            Chưa có địa chỉ nào được lưu
                                        </p>
                                        <Button onClick={() => setShowAddressModal(true)}>Thêm địa chỉ mới</Button>
                                    </Card>
                                ) : (
                                    <div className="space-y-4">
                                        {addresses.map((addr) => (
                                            <Card key={addr._id} className="p-6 flex justify-between items-start">
                                                <div>
                                                    <div className="font-bold mb-1">{addr.fullName}</div>
                                                    <div className="text-sm text-light-text-secondary dark:text-dark-text-secondary">{addr.phone}</div>
                                                    <div className="text-sm text-light-text-secondary dark:text-dark-text-secondary">{addr.address}, {addr.city}</div>
                                                </div>
                                                <Button variant="outline" size="sm" onClick={() => handleDeleteAddress(addr._id!)}>
                                                    Xóa
                                                </Button>
                                            </Card>
                                        ))}
                                        <Button onClick={() => setShowAddressModal(true)}>Thêm địa chỉ mới</Button>
                                    </div>
                                )}
                            </>
                        )}
                    </div>
                )}

                {activeTab === "favorites" && (
                    <div className="space-y-6">
                        <h2 className="text-2xl font-bold">Sách yêu thích</h2>
                        {loading ? (
                            <p>Đang tải...</p>
                        ) : favorites.length === 0 ? (
                            <Card className="p-8">
                                <p className="text-center text-light-text-secondary dark:text-dark-text-secondary">
                                    Bạn chưa có sách yêu thích nào
                                </p>
                            </Card>
                        ) : (
                            <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                                {favorites.map((book: any) => (
                                    <Card key={book._id} hover className="overflow-hidden" onClick={() => router.push(`/books/${book._id}`)}>
                                        <div className="aspect-[3/4] bg-gradient-to-br from-primary/10 to-secondary/10 flex items-center justify-center">
                                            {book.images && book.images.length > 0 ? (
                                                <img src={book.images[0]} alt={book.title} className="w-full h-full object-cover" />
                                            ) : (
                                                <div className="text-6xl">📖</div>
                                            )}
                                        </div>
                                        <div className="p-4">
                                            <h3 className="font-semibold mb-1 line-clamp-2">{book.title}</h3>
                                            <p className="text-sm text-light-text-secondary dark:text-dark-text-secondary mb-2">
                                                {book.author}
                                            </p>
                                            <div className="flex justify-between items-center">
                                                <span className="text-lg font-bold text-primary">{book.price?.toLocaleString('vi-VN')} ₫</span>
                                                <Button size="sm">{t("add")}</Button>
                                            </div>
                                        </div>
                                    </Card>
                                ))}
                            </div>
                        )}
                    </div>
                )}

                {activeTab === "settings" && (
                    <div className="space-y-6">
                        <h2 className="text-2xl font-bold">Cài đặt</h2>
                        <Card className="p-6">
                            <h3 className="text-xl font-semibold mb-4">Đổi mật khẩu</h3>
                            <div className="space-y-4">
                                <div>
                                    <label className="block text-sm font-medium mb-1">Mật khẩu hiện tại</label>
                                    <Input
                                        type="password"
                                        value={passwordData.currentPassword}
                                        onChange={(e) => setPasswordData({ ...passwordData, currentPassword: e.target.value })}
                                    />
                                </div>
                                <div>
                                    <label className="block text-sm font-medium mb-1">Mật khẩu mới</label>
                                    <Input
                                        type="password"
                                        value={passwordData.newPassword}
                                        onChange={(e) => setPasswordData({ ...passwordData, newPassword: e.target.value })}
                                    />
                                </div>
                                <div>
                                    <label className="block text-sm font-medium mb-1">Xác nhận mật khẩu mới</label>
                                    <Input
                                        type="password"
                                        value={passwordData.confirmPassword}
                                        onChange={(e) => setPasswordData({ ...passwordData, confirmPassword: e.target.value })}
                                    />
                                </div>
                                <div className="pt-4">
                                    <Button onClick={handleChangePassword} disabled={passwordLoading}>
                                        {passwordLoading ? "Đang xử lý..." : "Cập nhật mật khẩu"}
                                    </Button>
                                </div>
                            </div>
                        </Card>
                    </div>
                )}
            </>
                        )}
        </div>
                </div >
            </div >

        <Footer />
        </div >
    );
}
